# ================================================================================================
# 🏗️ PROJECT CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides for go-chaintracks
# Load Order: 90 (loaded after all defaults, overrides everything except 99-local.env)
#
# This file contains project-specific configuration that overrides the defaults
# defined in the 00-xx numbered env files. Only include variables that differ
# from the defaults.
#
# Maintainer: @mrz1836
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION CONFIGURATION
# ================================================================================================

# Primary Go version for builds and primary test runner
GO_PRIMARY_VERSION=1.26.x

# Secondary Go version for compatibility testing
GO_SECONDARY_VERSION=1.26.x

# MAGE-X Go version overrides
MAGE_X_GO_VERSION=1.26.x
MAGE_X_GO_SECONDARY_VERSION=1.26.x

# ================================================================================================
# 📊 COVERAGE CONFIGURATION
# ================================================================================================

# Coverage Provider Selection
GO_COVERAGE_PROVIDER=codecov

# Codecov Configuration
CODECOV_TOKEN_REQUIRED=true

# Coverage exclusions (matches codecov.yml ignore paths)
GO_COVERAGE_EXCLUDE_PATHS=.github/,.mage-cache/,.vscode/,bin/,example/,examples/,mocks/,testing/

# ================================================================================================
# 🔒 SECURITY CONFIGURATION
# ================================================================================================

# Nancy CVE Exclusions (known acceptable vulnerabilities)
NANCY_EXCLUDES=CVE-2024-38513,CVE-2023-45142,CVE-2025-64702,CVE-2021-43668,CVE-2023-26248,CVE-2026-26014,CVE-2026-26958,CVE-2025-15558,CVE-2026-33747,CVE-2026-33748,CVE-2026-33809,CVE-2026-34986,CVE-2026-33815,CVE-2026-33816,CVE-2026-39882,CVE-2026-39883,CVE-2026-35469,CVE-2026-5160,CVE-2026-33813

# Govulncheck/Magex CVE Exclusions
MAGE_X_CVE_EXCLUDES=CVE-2024-38513,CVE-2023-45142,CVE-2025-64702,CVE-2021-43668,CVE-2023-26248,CVE-2026-26014,CVE-2026-26958,CVE-2025-15558,CVE-2026-33747,CVE-2026-33748,CVE-2026-33809,CVE-2026-34986,CVE-2026-33815,CVE-2026-33816,CVE-2026-39882,CVE-2026-39883,CVE-2026-35469,CVE-2026-5160,CVE-2026-33813
