# ================================================================================================
# 🏗️ PROJECT-SPECIFIC CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides for this repository
# Load Order: 90 (loaded after all defaults, overrides earlier files)
#
# This file contains configuration values that are specific to this project
# and override the defaults defined in earlier env files (00-core, 10-*, 20-*).
#
# Only add variables here that differ from the defaults.
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION CONFIGURATION
# ================================================================================================

# Primary Go version for builds and primary test runner
GO_PRIMARY_VERSION=1.26.x

# Secondary Go version for compatibility testing
GO_SECONDARY_VERSION=1.26.x

# MAGE-X Go version overrides
MAGE_X_GO_VERSION=1.26.x
MAGE_X_GO_SECONDARY_VERSION=1.26.x

# ================================================================================================
# 📊 COVERAGE OVERRIDES
# ================================================================================================

# Custom Coverage Exclusions (overrides 10-coverage.env)
GO_COVERAGE_EXCLUDE_PATHS=.github/,.mage-cache/,.vscode/,bin/,docs/,example/,examples/,mocks/,plans/,test/,testing/,testdata/,vendor/

# Coverage Provider (overrides 10-coverage.env)
GO_COVERAGE_PROVIDER=codecov

# Codecov Configuration (overrides 10-coverage.env)
CODECOV_TOKEN_REQUIRED=true

# ================================================================================================
# 🔒 SECURITY CONFIGURATION
# ================================================================================================

# Nancy CVE Exclusions (known acceptable vulnerabilities)
NANCY_EXCLUDES=CVE-2026-26014,CVE-2026-26958,CVE-2025-15558,CVE-2023-26248,CVE-2026-26958,CVE-2026-33809,CVE-2026-33747,CVE-2026-33748,CVE-2026-34986,CVE-2026-33815,CVE-2026-33816,CVE-2026-39882,CVE-2026-35469,CVE-2026-5160,CVE-2026-33812,CVE-2026-33813

# Govulncheck/Magex CVE Exclusions
MAGE_X_CVE_EXCLUDES=CVE-2026-26014,CVE-2026-26958,CVE-2025-15558,CVE-2023-26248,CVE-2026-26958,CVE-2026-33809,CVE-2026-33747,CVE-2026-33748,CVE-2026-34986,CVE-2026-33815,CVE-2026-33816,CVE-2026-39882,CVE-2026-35469,CVE-2026-5160,CVE-2026-33812,CVE-2026-33813

# ================================================================================================
# 🏗️ BUILD OPTIMIZATION
# ================================================================================================

# Skip pre-building packages during cache warming to prevent OOM kills.
# Even batch_size=3 with GOGC=50 exceeds the ~7GB available on standard runners
# because heavy packages (cmd/certifier, cmd/infra) pull in the entire dependency
# tree (libp2p, k8s, googleapis, etc.).
# The module cache (go mod download) is still warmed — that provides the biggest
# speedup. Build artifacts get cached naturally after the first real build job.
MAGE_X_BUILD_STRATEGY=skip
