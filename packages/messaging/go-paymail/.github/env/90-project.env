# ================================================================================================
# 🏗️ PROJECT CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides for go-paymail
# Load Order: 90 (loaded after all tool defaults, overrides everything before it)
#
# This file contains project-specific settings that override the defaults defined
# in earlier configuration files (00-core.env, 10-*.env, 20-*.env).
#
# Override in: 99-local.env (local development only, git-ignored)
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION CONFIGURATION
# ================================================================================================

GO_PRIMARY_VERSION=1.25.x
GO_SECONDARY_VERSION=1.25.x
MAGE_X_GO_SECONDARY_VERSION=1.25.x
MAGE_X_GO_VERSION=1.25.x

# ================================================================================================
# 📊 COVERAGE PROVIDER
# ================================================================================================

# Use Codecov as the coverage provider (overrides 10-coverage.env default of "internal")
GO_COVERAGE_PROVIDER=codecov

# Require Codecov token for uploads
CODECOV_TOKEN_REQUIRED=true

# ================================================================================================
# 🚫 COVERAGE EXCLUSIONS
# ================================================================================================
# Paths excluded from coverage reporting (aligned with codecov.yml ignore patterns)

GO_COVERAGE_EXCLUDE_PATHS=.github/,.mage-cache/,.vscode/,bin/,example/,examples/,mocks/,testing/,test/,vendor/,testdata/

# ================================================================================================
# 🛡️ SECURITY EXCLUSIONS
# ================================================================================================

# Nancy CVE Exclusions (known acceptable vulnerabilities)
NANCY_EXCLUDES=CVE-2026-5160

# Govulncheck/Magex CVE Exclusions (known acceptable vulnerabilities)
MAGE_X_CVE_EXCLUDES=CVE-2026-5160
