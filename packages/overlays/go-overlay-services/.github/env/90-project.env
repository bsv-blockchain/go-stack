# ================================================================================================
# 🏗️ PROJECT-SPECIFIC CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides for go-overlay-services
# Load Order: 90 (loaded after all tool defaults, overrides everything except 99-local.env)
#
# This file contains project-specific configuration that overrides the defaults
# from earlier env files. Use this for:
# - Coverage provider and exclusion overrides
# - Project-specific feature flags
# - Custom tool settings
# - Nancy CVE exclusions
#
# Override in: 99-local.env (local development only, never committed)
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION OVERRIDES
# ================================================================================================

# Primary Go version for builds and primary test runner
GO_PRIMARY_VERSION=1.25.x

# Secondary Go version for compatibility testing
GO_SECONDARY_VERSION=1.25.x

# ================================================================================================
# 🔧 MAGE-X VERSION OVERRIDES
# ================================================================================================

MAGE_X_GO_VERSION=1.25.x
MAGE_X_GO_SECONDARY_VERSION=1.25.x

# ================================================================================================
# 📊 COVERAGE CONFIGURATION
# ================================================================================================

# Coverage Provider (overrides 10-coverage.env default of "internal")
GO_COVERAGE_PROVIDER=codecov

# Codecov Configuration
CODECOV_TOKEN_REQUIRED=true

# Coverage Exclusion Paths (aligned with codecov.yml ignore paths)
GO_COVERAGE_EXCLUDE_PATHS=test/,vendor/,testdata/,examples/,plans/,docs/,.github/,.mage-cache/,.vscode/,bin/,example/,mocks/,testing/

# Skip URL Checks in Coverage Reports
GO_COVERAGE_SKIP_URL_CHECKS=true

# ================================================================================================
# 🛡️ SECURITY EXCLUSIONS
# ================================================================================================

# Nancy CVE Exclusions (known acceptable vulnerabilities)
NANCY_EXCLUDES=CVE-2024-38513,CVE-2023-45142,CVE-2024-24786,CVE-2026-5160,CVE-2026-35469,CVE-2026-40890

# MageX CVE Exclusions (known acceptable vulnerabilities)
MAGE_X_CVE_EXCLUDES=CVE-2026-5160,CVE-2026-35469,CVE-2026-40890
