# ================================================================================================
# 🏗️ PROJECT-SPECIFIC CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides for go-overlay-discovery-services
# Load Order: 90 (loaded near-last, overrides all default/tool configurations)
#
# This file contains settings unique to this project that differ from the
# shared defaults in 00-core.env and 10-*.env files.
#
# Override in: 99-local.env (local development only, git-ignored)
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION OVERRIDES
# ================================================================================================

# Primary Go version for builds and primary test runner
GO_PRIMARY_VERSION=1.26.x

# Secondary Go version for compatibility testing
GO_SECONDARY_VERSION=1.26.x

# ================================================================================================
# 🔧 MAGE-X VERSION OVERRIDES
# ================================================================================================

MAGE_X_GO_VERSION=1.26.x
MAGE_X_GO_SECONDARY_VERSION=1.26.x

# ================================================================================================
# 📊 COVERAGE PROVIDER OVERRIDES
# ================================================================================================

# Coverage Provider Selection (this project uses codecov)
GO_COVERAGE_PROVIDER=codecov

# Codecov Configuration
CODECOV_TOKEN_REQUIRED=true

# Coverage Exclusions (matches codecov.yml ignore paths)
GO_COVERAGE_EXCLUDE_PATHS=.github/,.mage-cache/,.vscode/,bin/,example/,examples/,mocks/,testing/,test/,vendor/,testdata/

# ================================================================================================
# 🛡️ SECURITY SCANNER EXCLUSIONS
# ================================================================================================

# CVE-2026-26014 for github.com/pion/dtls/v2@v2.2.12
# Information Exposure (CWE-200) - Random nonce generation with GCM ciphers
# Affects: pion/dtls/v2 v1.0.0 through v2.2.12 (v2.2.12 is latest in v2 branch)
# Fixed in: pion/dtls/v3@v3.1.0+ (we have v3.1.1, which is safe)
# Dependency path: go-overlay-discovery-services → go-libp2p@v0.47.0 → pion/webrtc/v4 → pion/dtls/v2
# Status: Transitive dependency - cannot upgrade v2→v3 (different major versions)
# Mitigation: v3.1.1 is already present for WebRTC functionality
# Risk: Low - vulnerability in legacy v2 branch, safe v3 branch in use
# Monitoring: Track go-libp2p releases for removal of v2 dependency

# Nancy Security Scanner Exclusions (comma-separated CVE IDs)
NANCY_EXCLUDES=CVE-2024-38513,CVE-2023-45142,CVE-2025-11065,CVE-2026-26014,CVE-2025-15558,CVE-2026-33747,CVE-2026-33748,CVE-2026-33809,CVE-2026-34986,CVE-2026-33815,CVE-2026-33816,CVE-2026-39882,CVE-2026-39883,CVE-2026-5160,CVE-2026-35469,CVE-2026-33813,CVE-2026-33812

# Govulncheck/Magex CVE Exclusions
# CVE-2023-26248 (GO-2024-3218): libp2p-kad-dht content censorship via DHT abuse
# No fix available upstream; low risk for this application's use case
MAGE_X_CVE_EXCLUDES=CVE-2023-26248,CVE-2026-26014,CVE-2025-15558,CVE-2026-33747,CVE-2026-33748,CVE-2026-33809,CVE-2026-34986,CVE-2026-33815,CVE-2026-33816,CVE-2026-5160,CVE-2026-35469,CVE-2026-33813,CVE-2026-33812

# ================================================================================================
# ⚙️ BUILD CONFIGURATION
# ================================================================================================

# Disable cache warming pre-build - this repo's packages have 1750+ dependencies
# (due to go-sdk wallet and go-overlay-services imports) which causes OOM kills
# even with batch size 1 and parallelism 1 on GitHub Actions runners.
# Module cache still works; only build cache warming is disabled.
#ENABLE_CACHE_WARMING=false

# Skip Mage-X build steps that are not needed for this project to reduce build time and resource usage.
MAGE_X_BUILD_STRATEGY=skip
